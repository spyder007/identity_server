{
  "name": "admin-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint:fix": "eslint --report-unused-disable-directives --max-warnings 0 --fix && prettier --write",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0 && prettier",
    "preview": "vite preview",
    "test-ui": "vitest --ui --coverage",
    "test": "vitest --reporter=verbose",
    "test-ci": "vitest run --reporter junit --coverage",
    "api:spec": "curl -s -o openapi.json http://localhost:34150/openapi/v1.json",
    "api:generate": "openapi-ts",
    "api:update": "yarn api:spec && yarn api:generate"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@hey-api/client-axios": "^0.9.1",
    "axios": "^1.16.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.8",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.15.1",
    "redux": "^5.0.1",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "^0.97.1",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "@vitest/ui": "4.1.6",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "8.0.13",
    "vitest": "4.1.6",
    "vitest-dom": "^0.1.1"
  },
  "packageManager": "yarn@4.9.2"
}
