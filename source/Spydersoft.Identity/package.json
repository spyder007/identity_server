{
  "name": "@spydersoft/identity",
  "version": "1.0.10",
  "private": true,
  "description": "Identity Server 5 Implementation",
  "type": "module",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "aspnet-client-validation": "^0.9.4",
    "davidshimjs-qrcodejs": "^0.0.2",
    "moment": "^2.30.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19"
  },
  "scripts": {
    "copy": "node ./tools/copy-static.mjs",
    "build:css": "tailwindcss -i ./Styles/style.css -o ./wwwroot/css/style.css && tailwindcss -i ./Styles/style.css -o ./wwwroot/css/style.min.css --minify",
    "watch:css": "tailwindcss -i ./Styles/style.css -o ./wwwroot/css/style.css --watch",
    "build": "npm run copy && npm run build:css",
    "dev": "npm run copy && npm run watch:css",
    "develop": "npm run dev",
    "production": "npm run build"
  },
  "author": "Matthew Gerega",
  "homepage": "https://www.mattgerega.com",
  "copyright": "Copyright 2019 SpyderSoft Matthew Gerega",
  "license": "MIT"
}
