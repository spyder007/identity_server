@model LoginViewModel

@{
    ViewData["Title"] = "Switch Account";
    var provider = Model.VisibleExternalProviders.FirstOrDefault(p => p.AuthenticationScheme == Model.ExternalLoginScheme)
                   ?? Model.VisibleExternalProviders.FirstOrDefault();
    var providerName = provider?.DisplayName ?? Model.ExternalLoginScheme;
    var currentUser = User?.Identity?.Name;
}

<div class="min-h-screen bg-gradient-to-br from-blue-50 to-purple-50 flex items-center justify-center p-4">
    <div class="card bg-base-100 shadow-2xl max-w-lg w-full">
        <div class="card-body p-8 lg:p-12">
            <div class="text-center mb-6">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-warning/20 mb-4">
                    <i class="fas fa-user-shield text-warning text-2xl"></i>
                </div>
                <h2 class="text-2xl font-bold">Different sign-in required</h2>
            </div>

            <div class="alert alert-info mb-6">
                <i class="fas fa-info-circle"></i>
                <div class="text-sm">
                    @if (!string.IsNullOrEmpty(currentUser))
                    {
                        <p>You're signed in as <strong>@currentUser</strong>, but this application requires sign-in with <strong>@providerName</strong>.</p>
                    }
                    else
                    {
                        <p>This application requires sign-in with <strong>@providerName</strong>.</p>
                    }
                    <p class="mt-2">Continuing will switch your active session.</p>
                </div>
            </div>

            <div class="space-y-3">
                @if (provider != null)
                {
                    <form asp-controller="External" asp-action="Challenge" method="post">
                        <input type="hidden" name="scheme" value="@provider.AuthenticationScheme" />
                        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                        <button type="submit" class="btn btn-primary btn-lg w-full">
                            <i class="@provider.LniCssClass mr-2"></i>
                            Continue with @provider.DisplayName
                        </button>
                    </form>
                }

                <form asp-controller="Account" asp-action="Logout" method="get">
                    <button type="submit" class="btn btn-ghost btn-sm w-full">
                        Cancel and sign out
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
