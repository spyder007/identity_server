@page
@using Microsoft.AspNetCore.Hosting
@using Microsoft.Extensions.Hosting
@model Spydersoft.Identity.Pages.Home.ErrorModel
@inject IWebHostEnvironment Host
@{
    ViewData["Title"] = "Error";
    Layout = "_AuthLayout";
    var error = Model.View?.Error?.Error;
    var errorDescription = Host.IsDevelopment() ? Model.View?.Error?.ErrorDescription : null;
    var requestId = Model.View?.Error?.RequestId;
}

<div class="card">
    <div class="card-body text-center">
        <span class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-danger/10 text-danger">
            <i class="fas fa-triangle-exclamation text-2xl"></i>
        </span>
        <h1 class="text-xl font-semibold text-content">Something went wrong</h1>
        <p class="mt-2 text-sm text-content-muted">
            We encountered an unexpected error while processing your request.
        </p>

        @if (error != null || errorDescription != null)
        {
            <div class="alert alert-error mt-5 text-left">
                <i class="fas fa-bug mt-0.5"></i>
                <div>
                    @if (error != null)
                    {
                        <div class="font-semibold">@error</div>
                    }
                    @if (errorDescription != null)
                    {
                        <div class="mt-1 text-xs">@errorDescription</div>
                    }
                </div>
            </div>
        }

        @if (requestId != null)
        {
            <div class="mt-4 rounded-lg bg-surface-sunken px-4 py-3 text-left text-xs text-content-muted">
                <span class="font-medium">Request ID:</span>
                <code class="font-mono">@requestId</code>
            </div>
        }

        <div class="card-actions mt-6 justify-center">
            <a asp-page="/Index" class="btn btn-primary">
                <i class="fas fa-house"></i> Return Home
            </a>
        </div>
    </div>
</div>
