@page
@model Spydersoft.Identity.Pages.Manage.EnableAuthenticatorModel
@{
    ViewData["Title"] = "Authenticator App";
}

<partial name="_ManageNav" />

<div class="mt-6">
    <div class="card max-w-2xl">
        <div class="card-body">
            <h2 class="card-title">Configure authenticator app</h2>

            <ol class="mt-4 flex flex-col gap-5 text-sm text-content-muted">
                <li>
                    <p class="font-medium text-content">1. Scan the QR code or enter the key into your authenticator app.</p>
                    <div class="mt-3 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
                        <div id="qrCode" class="rounded-lg border border-border bg-white p-2"></div>
                        <span id="qrCodeData" data-url="@Model.Input.AuthenticatorUri" class="hidden"></span>
                        <div>
                            <div class="text-xs uppercase tracking-wider text-content-subtle">Setup key</div>
                            <div class="flex items-center gap-2">
                                <code id="sharedKey" class="font-mono text-sm text-content">@Model.Input.SharedKey</code>
                                <button type="button" class="btn btn-ghost btn-sm" data-copy-text="@Model.Input.SharedKey" aria-label="Copy key">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </li>
                <li>
                    <p class="font-medium text-content">2. Enter the 6-digit code from your app.</p>
                    <form method="post" class="mt-3">
                        <partial name="_ValidationSummary" />
                        <input type="hidden" asp-for="Input.SharedKey" />
                        <input type="hidden" asp-for="Input.AuthenticatorUri" />
                        <div class="flex items-start gap-2">
                            <div class="flex-1">
                                <input class="input text-center tracking-widest" asp-for="Input.Code"
                                       inputmode="numeric" autocomplete="one-time-code" placeholder="000000" />
                                <span class="form-error" asp-validation-for="Input.Code"></span>
                            </div>
                            <button type="submit" class="btn btn-primary shrink-0"><i class="fas fa-check"></i> Verify</button>
                        </div>
                    </form>
                </li>
            </ol>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/davidshimjs-qrcodejs/qrcode.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
