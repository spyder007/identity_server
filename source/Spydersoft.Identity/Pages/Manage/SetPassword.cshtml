@page
@model Spydersoft.Identity.Pages.Manage.SetPasswordModel
@{
    ViewData["Title"] = "Set Password";
}

<partial name="_ManageNav" />

<div class="mt-6">
    <partial name="_StatusMessage" model="Model.StatusMessage" />

    <div class="card max-w-xl">
        <div class="card-body">
            <h2 class="card-title">Set password</h2>
            <p class="mt-1 text-sm text-content-muted">
                You signed in with an external provider and don't have a local password yet. Set one to enable username/password login.
            </p>
            <form method="post" class="mt-4">
                <partial name="_ValidationSummary" />
                <div class="form-field">
                    <label class="form-label" asp-for="Input.NewPassword">New password</label>
                    <input class="input" asp-for="Input.NewPassword" type="password" autocomplete="new-password" />
                    <span class="form-error" asp-validation-for="Input.NewPassword"></span>
                </div>
                <div class="form-field">
                    <label class="form-label" asp-for="Input.ConfirmPassword">Confirm password</label>
                    <input class="input" asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                    <span class="form-error" asp-validation-for="Input.ConfirmPassword"></span>
                </div>
                <div class="card-actions justify-end">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-key"></i> Set password</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
