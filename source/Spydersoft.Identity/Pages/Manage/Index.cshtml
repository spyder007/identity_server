@page
@model Spydersoft.Identity.Pages.Manage.IndexModel
@{
    ViewData["Title"] = "Profile";
}

<partial name="_ManageNav" />

<div class="mt-6">
    <partial name="_StatusMessage" model="Model.StatusMessage" />

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
        <div class="lg:col-span-2">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title">Account information</h2>
                    <p class="mt-1 text-sm text-content-muted">Update your personal details.</p>

                    <form method="post" class="mt-4">
                        <partial name="_ValidationSummary" />

                        <div class="form-field">
                            <label class="form-label" asp-for="Input.Username">Username</label>
                            <input class="input" asp-for="Input.Username" disabled />
                            <span class="form-hint">Your username cannot be changed.</span>
                        </div>

                        <div class="form-field">
                            <div class="flex items-center justify-between">
                                <label class="form-label" asp-for="Input.Email">Email</label>
                                @if (Model.Input.IsEmailConfirmed)
                                {
                                    <span class="badge badge-success"><i class="fas fa-check text-xs"></i> Verified</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning"><i class="fas fa-exclamation text-xs"></i> Not verified</span>
                                }
                            </div>
                            <div class="flex gap-2">
                                <input class="input" asp-for="Input.Email" type="email" />
                                @if (!Model.Input.IsEmailConfirmed)
                                {
                                    <button type="submit" asp-page-handler="SendVerificationEmail" class="btn btn-outline btn-sm shrink-0">
                                        <i class="fas fa-envelope"></i> Verify
                                    </button>
                                }
                            </div>
                            <span class="form-error" asp-validation-for="Input.Email"></span>
                        </div>

                        <div class="form-field">
                            <label class="form-label" asp-for="Input.PhoneNumber">Phone number</label>
                            <input class="input" asp-for="Input.PhoneNumber" type="tel" placeholder="Optional" />
                            <span class="form-error" asp-validation-for="Input.PhoneNumber"></span>
                        </div>

                        <div class="card-actions justify-end">
                            <button type="submit" class="btn btn-primary"><i class="fas fa-floppy-disk"></i> Save changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="card h-fit">
            <div class="card-body">
                <h3 class="card-title text-base">Account status</h3>
                <dl class="mt-3 flex flex-col gap-3 text-sm">
                    <div class="flex items-center justify-between">
                        <dt class="text-content-muted">Email verified</dt>
                        <dd>
                            @if (Model.Input.IsEmailConfirmed)
                            {
                                <span class="badge badge-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">Pending</span>
                            }
                        </dd>
                    </div>
                    <div class="flex items-center justify-between">
                        <dt class="text-content-muted">Phone number</dt>
                        <dd>
                            @if (!string.IsNullOrEmpty(Model.Input.PhoneNumber))
                            {
                                <span class="badge badge-success">Added</span>
                            }
                            else
                            {
                                <span class="badge badge-neutral">None</span>
                            }
                        </dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
