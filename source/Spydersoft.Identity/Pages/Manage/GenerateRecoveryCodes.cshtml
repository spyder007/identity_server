@page
@model Spydersoft.Identity.Pages.Manage.GenerateRecoveryCodesModel
@{
    ViewData["Title"] = "Recovery Codes";
}

<partial name="_ManageNav" />

<div class="mt-6">
    <div class="card max-w-2xl">
        <div class="card-body">
            <h2 class="card-title">Recovery codes</h2>
            <div class="alert alert-warning mt-4">
                <i class="fas fa-triangle-exclamation mt-0.5"></i>
                <span>Store these codes somewhere safe. Each code can be used once if you lose access to your authenticator app.</span>
            </div>

            <div class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-3">
                @foreach (var code in Model.View.RecoveryCodes)
                {
                    <code class="rounded-md bg-surface-sunken px-3 py-2 text-center font-mono text-sm text-content">@code</code>
                }
            </div>

            <div class="card-actions mt-6">
                <a asp-page="/Manage/TwoFactorAuthentication" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back to two-factor</a>
            </div>
        </div>
    </div>
</div>
