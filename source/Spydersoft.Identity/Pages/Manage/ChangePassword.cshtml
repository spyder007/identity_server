@page
@model Spydersoft.Identity.Pages.Manage.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<partial name="_ManageNav" />

<div class="mt-6">
    <partial name="_StatusMessage" model="Model.StatusMessage" />

    <div class="card max-w-xl">
        <div class="card-body">
            <h2 class="card-title">Change password</h2>
            <form method="post" class="mt-4">
                <partial name="_ValidationSummary" />
                <div class="form-field">
                    <label class="form-label" asp-for="Input.OldPassword">Current password</label>
                    <input class="input" asp-for="Input.OldPassword" type="password" autocomplete="current-password" />
                    <span class="form-error" asp-validation-for="Input.OldPassword"></span>
                </div>
                <div class="form-field">
                    <label class="form-label" asp-for="Input.NewPassword">New password</label>
                    <input class="input" asp-for="Input.NewPassword" type="password" autocomplete="new-password" />
                    <span class="form-error" asp-validation-for="Input.NewPassword"></span>
                </div>
                <div class="form-field">
                    <label class="form-label" asp-for="Input.ConfirmPassword">Confirm new password</label>
                    <input class="input" asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                    <span class="form-error" asp-validation-for="Input.ConfirmPassword"></span>
                </div>
                <div class="card-actions justify-end">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-key"></i> Update password</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
