@page
@{
    ViewData["Title"] = "Device Authorized";
    Layout = "_AuthLayout";
}

<div class="card">
    <div class="card-body text-center">
        <span class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-success/10 text-success">
            <i class="fas fa-circle-check text-2xl"></i>
        </span>
        <h1 class="text-xl font-semibold text-content">All set</h1>
        <p class="mt-2 text-sm text-content-muted">
            Your device has been authorized. You can now return to your device &mdash; it's safe to close this window.
        </p>
    </div>
</div>
