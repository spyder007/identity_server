@page
@using System
@model Spydersoft.Identity.Pages.Grants.IndexModel
@{
    ViewData["Title"] = "Applications";
}

<div class="mb-6">
    <h1 class="text-2xl font-semibold text-content">Application permissions</h1>
    <p class="mt-1 text-sm text-content-muted">Applications you've granted access to, and what they can see.</p>
</div>

@if (!Model.View.Grants.Any())
{
    <div class="card">
        <div class="card-body py-12 text-center">
            <span class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-surface-sunken text-content-subtle">
                <i class="fas fa-shield-halved text-xl"></i>
            </span>
            <h2 class="text-lg font-semibold text-content">No application permissions</h2>
            <p class="mt-1 text-sm text-content-muted">Applications you sign in to will appear here.</p>
        </div>
    </div>
}
else
{
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        @foreach (var grant in Model.View.Grants)
        {
            var expired = grant.Expires.HasValue && grant.Expires.Value < DateTime.UtcNow;
            <div class="card">
                <div class="card-body">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex min-w-0 items-center gap-3">
                            @if (grant.ClientLogoUrl != null)
                            {
                                <img src="@grant.ClientLogoUrl" alt="@grant.ClientName" class="h-10 w-10 rounded-lg object-contain" />
                            }
                            else
                            {
                                <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-soft text-brand">
                                    <i class="fas fa-cube"></i>
                                </span>
                            }
                            <div class="min-w-0">
                                <h3 class="truncate font-semibold text-content">@grant.ClientName</h3>
                                <div class="text-xs text-content-subtle">
                                    Created @grant.Created.ToString("MMM dd, yyyy")
                                    @if (grant.Expires.HasValue)
                                    {
                                        <span>&middot; @(expired ? "Expired" : "Expires") @grant.Expires.Value.ToString("MMM dd, yyyy")</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <form method="post" asp-page-handler="Revoke" class="shrink-0">
                            <input type="hidden" name="clientId" value="@grant.ClientId" />
                            <button type="submit" class="btn btn-ghost btn-sm text-danger"><i class="fas fa-xmark"></i> Revoke</button>
                        </form>
                    </div>

                    @if (!string.IsNullOrEmpty(grant.Description))
                    {
                        <p class="mt-3 text-sm text-content-muted">@grant.Description</p>
                    }

                    @if (grant.IdentityGrantNames.Any() || grant.ApiGrantNames.Any())
                    {
                        <div class="mt-3 flex flex-wrap gap-2">
                            @foreach (var name in grant.IdentityGrantNames)
                            {
                                <span class="badge badge-brand">@name</span>
                            }
                            @foreach (var name in grant.ApiGrantNames)
                            {
                                <span class="badge badge-neutral">@name</span>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
