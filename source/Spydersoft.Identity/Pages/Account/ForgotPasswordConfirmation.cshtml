@page
@{
    ViewData["Title"] = "Check Your Email";
    Layout = "_AuthLayout";
}

<div class="card">
    <div class="card-body text-center">
        <span class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-brand-soft text-brand">
            <i class="fas fa-envelope text-2xl"></i>
        </span>
        <h1 class="text-xl font-semibold text-content">Check your email</h1>
        <p class="mt-2 text-sm text-content-muted">
            If an account exists for that address, we've sent a link to reset your password.
        </p>
        <div class="card-actions mt-6 justify-center">
            <a asp-page="/Account/Login" class="btn btn-primary"><i class="fas fa-right-to-bracket"></i> Back to sign in</a>
        </div>
    </div>
</div>
