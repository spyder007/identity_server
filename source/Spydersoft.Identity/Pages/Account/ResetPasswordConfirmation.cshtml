@page
@{
    ViewData["Title"] = "Password Reset";
    Layout = "_AuthLayout";
}

<div class="card">
    <div class="card-body text-center">
        <span class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-success/10 text-success">
            <i class="fas fa-circle-check text-2xl"></i>
        </span>
        <h1 class="text-xl font-semibold text-content">Password reset</h1>
        <p class="mt-2 text-sm text-content-muted">Your password has been reset. You can now sign in with your new password.</p>
        <div class="card-actions mt-6 justify-center">
            <a asp-page="/Account/Login" class="btn btn-primary"><i class="fas fa-right-to-bracket"></i> Sign in</a>
        </div>
    </div>
</div>
