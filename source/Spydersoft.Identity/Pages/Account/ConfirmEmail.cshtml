@page
@model Spydersoft.Identity.Pages.Account.ConfirmEmailModel
@{
    ViewData["Title"] = "Confirm Email";
    Layout = "_AuthLayout";
}

<div class="card">
    <div class="card-body text-center">
        @if (Model.Succeeded)
        {
            <span class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-success/10 text-success">
                <i class="fas fa-circle-check text-2xl"></i>
            </span>
        }
        else
        {
            <span class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-danger/10 text-danger">
                <i class="fas fa-circle-exclamation text-2xl"></i>
            </span>
        }
        <h1 class="text-xl font-semibold text-content">@Model.Message</h1>
        <div class="card-actions mt-6 justify-center">
            <a asp-page="/Account/Login" class="btn btn-primary"><i class="fas fa-right-to-bracket"></i> Sign in</a>
        </div>
    </div>
</div>
