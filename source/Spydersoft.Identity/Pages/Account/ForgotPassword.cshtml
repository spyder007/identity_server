@page
@model Spydersoft.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<div class="card">
    <div class="card-body">
        <div class="mb-6 text-center">
            <h1 class="text-xl font-semibold text-content">Forgot your password?</h1>
            <p class="mt-1 text-sm text-content-muted">Enter your email and we'll send you a reset link.</p>
        </div>

        <form method="post">
            <partial name="_ValidationSummary" />
            <div class="form-field">
                <label class="form-label" asp-for="Input.Email">Email</label>
                <input class="input" asp-for="Input.Email" type="email" autocomplete="email" placeholder="you@example.com" />
                <span class="form-error" asp-validation-for="Input.Email"></span>
            </div>
            <button type="submit" class="btn btn-primary btn-block btn-lg mt-2">
                <i class="fas fa-paper-plane"></i> Send reset link
            </button>
        </form>

        <p class="mt-6 text-center text-sm text-content-muted">
            Remembered it? <a asp-page="/Account/Login" class="link font-medium">Back to sign in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
