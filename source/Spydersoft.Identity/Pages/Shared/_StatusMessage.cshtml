@model string

@if (!string.IsNullOrEmpty(Model))
{
    var isError = Model.StartsWith("Error", StringComparison.Ordinal);
    <div class="alert @(isError ? "alert-error" : "alert-success") mb-4" role="alert">
        <i class="fas @(isError ? "fa-circle-exclamation" : "fa-circle-check") mt-0.5"></i>
        <span>@Model</span>
    </div>
}
