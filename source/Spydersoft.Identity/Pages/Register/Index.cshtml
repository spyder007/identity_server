@page
@model Spydersoft.Identity.Pages.Register.IndexModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_AuthLayout";
}

<div class="card">
    <div class="card-body">
        <div class="mb-6 text-center">
            <h1 class="text-xl font-semibold text-content">Create your account</h1>
            <p class="mt-1 text-sm text-content-muted">Join Spydersoft Identity</p>
        </div>

        <form method="post">
            <partial name="_ValidationSummary" />
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="form-field">
                <label class="form-label" asp-for="Input.Name">Name</label>
                <input class="input" asp-for="Input.Name" autocomplete="name" placeholder="Your name" />
                <span class="form-error" asp-validation-for="Input.Name"></span>
            </div>
            <div class="form-field">
                <label class="form-label" asp-for="Input.Email">Email</label>
                <input class="input" asp-for="Input.Email" type="email" autocomplete="email" placeholder="you@example.com" />
                <span class="form-error" asp-validation-for="Input.Email"></span>
            </div>
            <div class="form-field">
                <label class="form-label" asp-for="Input.Password">Password</label>
                <input class="input" asp-for="Input.Password" type="password" autocomplete="new-password" />
                <span class="form-error" asp-validation-for="Input.Password"></span>
            </div>
            <div class="form-field">
                <label class="form-label" asp-for="Input.ConfirmPassword">Confirm password</label>
                <input class="input" asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                <span class="form-error" asp-validation-for="Input.ConfirmPassword"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg mt-2">
                <i class="fas fa-user-plus"></i> Create account
            </button>
        </form>

        <p class="mt-6 text-center text-sm text-content-muted">
            Already have an account?
            <a asp-page="/Account/Login" asp-route-returnurl="@Model.ReturnUrl" class="link font-medium">Sign in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
