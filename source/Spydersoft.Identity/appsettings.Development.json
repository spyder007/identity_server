{
  "ConnectionStrings": {
    "IdentityConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    },
    "OpenTelemetry": {
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Debug",
        "System": "Debug"
      }
    }
  },
  "Telemetry": {
    "Log": {
      "Type": "console"
    },
    "Metrics": {
      "Type": "console"
    },
    "Trace": {
      "Type": "console"
    }
  }
}