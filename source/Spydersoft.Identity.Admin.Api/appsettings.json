{
  "ConnectionStrings": {
    "IdentityConnection": ""
  },
  "IdentityServer": {
    "Authority": ""
  },
  "AutoMapper": {
    "License": ""
  },
  "Logging": {
    "OpenTelemetry": {
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    }
  },
  "Telemetry": {
    "ActivitySourceName": "identity.admin.api",
    "Log": {
      "Otlp": {
        "Endpoint": ""
      },
      "Type": "otlp"
    },
    "MeterName": "identity.admin.api",
    "Metrics": {
      "Otlp": {
        "Endpoint": ""
      },
      "Type": "otlp"
    },
    "ServiceName": "identity.admin.api",
    "Trace": {
      "Otlp": {
        "Endpoint": ""
      },
      "Type": "otlp"
    }
  },
  "HealthChecks": {
    "Path": "/health"
  }
}
